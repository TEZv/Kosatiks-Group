{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "game.kosatiks-group.pp.ua" }],
      "destination": "/game/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "game.kosatiks-group.pp.ua" }],
      "destination": "/game/$1"
    }
  ]
}
