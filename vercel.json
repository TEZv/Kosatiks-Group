{
  "installCommand": "",
  "buildCommand": "",
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "game.kosatiks-group.pp.ua" }],
      "destination": "/game/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "game.kosatiks-group.pp.ua" }],
      "destination": "/game/$1"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/game/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
